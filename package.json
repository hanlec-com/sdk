{
  "name": "@hanlec/sdk",
  "version": "0.2.0",
  "description": "Hanlec's SDK for fuller-stack development",
  "keywords": [
    "api",
    "hanlec",
    "sdk"
  ],
  "homepage": "https://hanlec.com",
  "bugs": {
    "url": "https://github.com/hanlec-com/sdk/issues",
    "email": "support@hanlec.com"
  },
  "license": "MIT",
  "author": {
    "name": "Vitor Manuel de Sousa Pereira",
    "email": "vitor@hanlec.com",
    "url": "https://hanlec.com"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./xjson": "./dist/xjson.js",
    "./vite": "./dist/vite.js"
  },
  "type": "module",
  "bin": {
    "hanlec": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hanlec-com/sdk.git"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@remix-run/node-fetch-server": "^0.13.0",
    "cac": "^6.7.14",
    "vite-console-forward-plugin": "^2.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@react-router/dev": "^7.14.0",
    "react-router": "7.x",
    "vite": "7.x"
  },
  "publishConfig": {
    "access": "public"
  }
}
